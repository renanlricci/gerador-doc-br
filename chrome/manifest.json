{
  "manifest_version": 3,
  "name": "Gerador Doc BR",
  "version": "1.1.1",
  "homepage_url": "https://github.com/renanlricci/gerador-doc-br",
  "description": "Gera números de documentos brasileiros DE TESTE (CPF, CNPJ, CNH, PIS, RENAVAM, RG e mais) pelo menu do botão direito.",
  "minimum_chrome_version": "88",
  "permissions": ["contextMenus", "clipboardWrite", "storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gerador Doc BR",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
