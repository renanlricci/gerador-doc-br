{
  "manifest_version": 2,
  "name": "Gerador Doc BR",
  "version": "1.1.0",
  "homepage_url": "https://github.com/renanlricci/gerador-doc-br",
  "description": "Gera números de documentos brasileiros DE TESTE (CPF, CNPJ, CNPJ alfanumérico, CNH, PIS/PASEP, RENAVAM, RG, Título de Eleitor) pelo menu do botão direito: copiar ou preencher o campo clicado. / Generates Brazilian TEST document numbers via right-click menu.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gerador-doc-br@renan.dev",
      "strict_min_version": "140.0",
      "update_url": "https://raw.githubusercontent.com/renanlricci/gerador-doc-br/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["menus", "clipboardWrite", "storage", "activeTab"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg",
    "default_title": "Gerador Doc BR"
  },
  "background": {
    "scripts": ["browser-shim.js", "i18n.js", "generator.js", "doc-types.js", "menus.js", "background.js"]
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}
